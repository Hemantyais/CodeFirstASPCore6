@model CodeFirstASPCore6.Models.Student

@{
    ViewData["Title"] = "Create Student";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;900&family=Rajdhani:wght@300;400;500;600&display=swap');

    :root {
        --neon-cyan: #00f5ff;
        --neon-purple: #bf00ff;
        --neon-green: #00ff88;
        --bg-deep: #03040a;
        --bg-card: #080d1a;
        --bg-input: #0a1020;
        --border-glow: rgba(0, 245, 255, 0.3);
        --text-primary: #e0f4ff;
        --text-muted: #4a7a8a;
        --grid-color: rgba(0, 245, 255, 0.04);
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    /* ── Override default ASP.NET Bootstrap navbar ── */
    body {
        background: var(--bg-deep) !important;
        margin: 0 !important;
        padding: 0 !important;
    }

    /* Target the default _Layout navbar */
    header,
    .navbar,
    nav.navbar {
        background: rgba(3, 4, 10, 0.92) !important;
        border-bottom: 1px solid rgba(0, 245, 255, 0.15) !important;
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        box-shadow: 0 1px 0 rgba(0, 245, 255, 0.08), 0 4px 24px rgba(0, 0, 0, 0.6) !important;
        padding: 0 !important;
    }

    .navbar-brand {
        font-family: 'Orbitron', monospace !important;
        font-size: 13px !important;
        font-weight: 700 !important;
        letter-spacing: 3px !important;
        text-transform: uppercase !important;
        color: var(--neon-cyan) !important;
        text-shadow: 0 0 12px rgba(0, 245, 255, 0.5) !important;
        padding: 14px 0 !important;
        text-decoration: none !important;
    }

        .navbar-brand:hover {
            color: #fff !important;
            text-shadow: 0 0 20px rgba(0, 245, 255, 0.8) !important;
        }

    .nav-link,
    .navbar-nav .nav-link {
        font-family: 'Orbitron', monospace !important;
        font-size: 9px !important;
        font-weight: 600 !important;
        letter-spacing: 3px !important;
        text-transform: uppercase !important;
        color: rgba(74, 122, 138, 0.9) !important;
        padding: 14px 16px !important;
        position: relative !important;
        transition: color 0.3s !important;
        text-decoration: none !important;
    }

        .nav-link::after,
        .navbar-nav .nav-link::after {
            content: '' !important;
            position: absolute !important;
            bottom: 8px !important;
            left: 16px !important;
            right: 16px !important;
            height: 1px !important;
            background: var(--neon-cyan) !important;
            transform: scaleX(0) !important;
            transition: transform 0.3s ease !important;
        }

        .nav-link:hover,
        .navbar-nav .nav-link:hover,
        .nav-link.active,
        .navbar-nav .nav-link.active {
            color: var(--neon-cyan) !important;
        }

            .nav-link:hover::after,
            .navbar-nav .nav-link:hover::after {
                transform: scaleX(1) !important;
            }

    .navbar-toggler {
        border: 1px solid rgba(0, 245, 255, 0.3) !important;
        border-radius: 2px !important;
        padding: 6px 10px !important;
    }

    .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(0, 245, 255, 0.8)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    }

    .navbar-collapse,
    .collapse.navbar-collapse {
        background: transparent !important;
    }

    /* Futuristic left accent bar on navbar */
    header::before,
    .navbar::before {
        content: '' !important;
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        bottom: 0 !important;
        width: 3px !important;
        background: linear-gradient(180deg, var(--neon-cyan), var(--neon-purple)) !important;
        z-index: 10 !important;
    }

    header {
        position: relative !important;
    }

    /* Remove any white/light backgrounds from layout wrapper */
    .container-fluid,
    .container {
        background: transparent !important;
    }

    /* Page body area */
    main, [role="main"] {
        background: var(--bg-deep) !important;
        min-height: calc(100vh - 60px) !important;
    }

    footer {
        background: rgba(3, 4, 10, 0.95) !important;
        border-top: 1px solid rgba(0, 245, 255, 0.1) !important;
        color: var(--text-muted) !important;
    }

        footer a {
            color: rgba(0, 245, 255, 0.5) !important;
            text-decoration: none !important;
            font-family: 'Orbitron', monospace !important;
            font-size: 9px !important;
            letter-spacing: 2px !important;
        }

            footer a:hover {
                color: var(--neon-cyan) !important;
            }

    .futuristic-wrapper {
        min-height: 100vh;
        background: var(--bg-deep);
        font-family: 'Rajdhani', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        position: relative;
        overflow: hidden;
    }

        /* Grid background */
        .futuristic-wrapper::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: linear-gradient(var(--grid-color) 1px, transparent 1px), linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }

    /* Ambient glow orbs */
    .orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        pointer-events: none;
        z-index: 0;
        opacity: 0.15;
    }

    .orb-1 {
        width: 400px;
        height: 400px;
        background: var(--neon-cyan);
        top: -100px;
        left: -100px;
        animation: orb-drift 12s ease-in-out infinite alternate;
    }

    .orb-2 {
        width: 300px;
        height: 300px;
        background: var(--neon-purple);
        bottom: -80px;
        right: -80px;
        animation: orb-drift 9s ease-in-out infinite alternate-reverse;
    }

    @@keyframes orb-drift {
        from {
            transform: translate(0, 0);
        }

        to {
            transform: translate(40px, 30px);
        }
    }

    /* Card */
    .card-wrapper {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 560px;
    }

    .form-card {
        background: var(--bg-card);
        border: 1px solid var(--border-glow);
        border-radius: 2px;
        padding: 48px 44px;
        position: relative;
        box-shadow: 0 0 40px rgba(0, 245, 255, 0.06), 0 0 80px rgba(0, 245, 255, 0.03), inset 0 1px 0 rgba(0, 245, 255, 0.1);
        animation: card-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes card-in {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* Corner accents */
    .form-card::before,
    .form-card::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border-color: var(--neon-cyan);
        border-style: solid;
    }

    .form-card::before {
        top: -1px;
        left: -1px;
        border-width: 2px 0 0 2px;
    }

    .form-card::after {
        bottom: -1px;
        right: -1px;
        border-width: 0 2px 2px 0;
    }

    /* Header */
    .form-header {
        margin-bottom: 40px;
        text-align: center;
    }

    .form-badge {
        display: inline-block;
        font-family: 'Orbitron', monospace;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 4px;
        color: var(--neon-cyan);
        text-transform: uppercase;
        background: rgba(0, 245, 255, 0.08);
        border: 1px solid rgba(0, 245, 255, 0.2);
        padding: 5px 16px;
        border-radius: 1px;
        margin-bottom: 20px;
    }

    .form-title {
        font-family: 'Orbitron', monospace;
        font-size: 28px;
        font-weight: 900;
        color: var(--text-primary);
        letter-spacing: 2px;
        line-height: 1.1;
        text-shadow: 0 0 20px rgba(0, 245, 255, 0.3);
    }

        .form-title span {
            color: var(--neon-cyan);
        }

    .form-subtitle {
        margin-top: 10px;
        font-size: 13px;
        letter-spacing: 1px;
        color: var(--text-muted);
        font-weight: 400;
    }

    /* Divider */
    .neon-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
        margin: 0 0 36px 0;
        opacity: 0.4;
    }

    /* Form groups */
    .field-group {
        margin-bottom: 24px;
        animation: field-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

        .field-group:nth-child(1) {
            animation-delay: 0.1s;
        }

        .field-group:nth-child(2) {
            animation-delay: 0.18s;
        }

        .field-group:nth-child(3) {
            animation-delay: 0.26s;
        }

        .field-group:nth-child(4) {
            animation-delay: 0.34s;
        }

    @@keyframes field-in {
        from {
            opacity: 0;
            transform: translateX(-12px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .field-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Orbitron', monospace;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 3px;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 8px;
        transition: color 0.3s;
    }

        .field-label .label-dot {
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--neon-cyan);
            opacity: 0.5;
            flex-shrink: 0;
        }

    .field-wrapper {
        position: relative;
    }

    .field-input {
        width: 100%;
        background: var(--bg-input);
        border: 1px solid rgba(0, 245, 255, 0.12);
        border-radius: 2px;
        color: var(--text-primary);
        font-family: 'Rajdhani', sans-serif;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: 1px;
        padding: 14px 18px 14px 44px;
        outline: none;
        transition: all 0.3s ease;
        -webkit-appearance: none;
    }

        .field-input::placeholder {
            color: rgba(74, 122, 138, 0.5);
            font-size: 13px;
            letter-spacing: 1px;
        }

        .field-input:focus {
            border-color: var(--neon-cyan);
            background: rgba(0, 245, 255, 0.03);
            box-shadow: 0 0 0 1px rgba(0, 245, 255, 0.15), 0 0 20px rgba(0, 245, 255, 0.06), inset 0 0 10px rgba(0, 245, 255, 0.02);
            color: #fff;
        }

            .field-input:focus + .field-line {
                width: 100%;
                opacity: 1;
            }

            .field-input:focus ~ .field-icon {
                color: var(--neon-cyan);
            }

    .field-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 15px;
        transition: color 0.3s;
        pointer-events: none;
    }

    .field-line {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 1px;
        width: 0;
        background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
        opacity: 0;
        transition: width 0.4s ease, opacity 0.3s;
        border-radius: 0 0 2px 2px;
    }

    .field-input:focus ~ .field-label-text {
        color: var(--neon-cyan);
    }

    .field-group:focus-within .field-label {
        color: var(--neon-cyan);
    }

    .field-group:focus-within .label-dot {
        opacity: 1;
        box-shadow: 0 0 6px var(--neon-cyan);
    }

    /* Validation */
    .field-error {
        display: block;
        font-size: 11px;
        letter-spacing: 1px;
        color: #ff4466;
        margin-top: 6px;
        padding-left: 4px;
        font-family: 'Rajdhani', sans-serif;
    }

    .validation-summary {
        background: rgba(255, 68, 102, 0.08);
        border: 1px solid rgba(255, 68, 102, 0.3);
        border-radius: 2px;
        padding: 12px 16px;
        margin-bottom: 24px;
        color: #ff4466;
        font-size: 13px;
        letter-spacing: 0.5px;
    }

    /* Submit button */
    .submit-row {
        margin-top: 36px;
        animation: field-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.42s both;
    }

    .btn-futuristic {
        width: 100%;
        position: relative;
        background: transparent;
        border: 1px solid var(--neon-cyan);
        border-radius: 2px;
        color: var(--neon-cyan);
        font-family: 'Orbitron', monospace;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        padding: 16px 32px;
        cursor: pointer;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .btn-futuristic::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
            opacity: 0;
            transition: opacity 0.3s;
        }

        .btn-futuristic:hover::before {
            opacity: 0.12;
        }

        .btn-futuristic:hover {
            box-shadow: 0 0 20px rgba(0, 245, 255, 0.25), 0 0 40px rgba(0, 245, 255, 0.1), inset 0 0 20px rgba(0, 245, 255, 0.05);
            transform: translateY(-1px);
            letter-spacing: 5px;
        }

        .btn-futuristic:active {
            transform: translateY(0);
            box-shadow: 0 0 10px rgba(0, 245, 255, 0.2);
        }

        .btn-futuristic span {
            position: relative;
            z-index: 1;
        }

        /* Scan line animation */
        .btn-futuristic::after {
            content: '';
            position: absolute;
            top: -100%;
            left: -10%;
            width: 120%;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(0, 245, 255, 0.8), transparent);
            transition: top 0.4s ease;
        }

        .btn-futuristic:hover::after {
            top: 110%;
        }

    /* Back link */
    .back-link-row {
        margin-top: 24px;
        text-align: center;
        animation: field-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-family: 'Orbitron', monospace;
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        transition: color 0.3s;
        padding: 8px 0;
    }

        .back-link:hover {
            color: var(--neon-cyan);
        }

        .back-link::before {
            content: '←';
            font-size: 14px;
            transition: transform 0.3s;
        }

        .back-link:hover::before {
            transform: translateX(-4px);
        }

    /* Gender select shimmer */
    select.field-input {
        cursor: pointer;
    }

        select.field-input option {
            background: #080d1a;
            color: var(--text-primary);
        }

    /* ID counter in corner */
    .form-id {
        position: absolute;
        top: 16px;
        right: 20px;
        font-family: 'Orbitron', monospace;
        font-size: 9px;
        letter-spacing: 2px;
        color: rgba(0, 245, 255, 0.2);
    }
</style>

<div class="futuristic-wrapper">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="card-wrapper">
        <div class="form-card">
            <div class="form-id">SYS::REG_FORM</div>

            <div class="form-header">
                <div class="form-badge">New Entry</div>
                <h1 class="form-title">REGISTER <span>STUDENT</span></h1>
                <p class="form-subtitle">INITIALIZE STUDENT RECORD // PROVIDE REQUIRED DATA</p>
            </div>

            <div class="neon-divider"></div>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="validation-summary text-danger"></div>

                <!-- Name -->
                <div class="field-group">
                    <label asp-for="Name" class="field-label">
                        <span class="label-dot"></span>
                        Student Name
                    </label>
                    <div class="field-wrapper">
                        <span class="field-icon">◈</span>
                        <input asp-for="Name" class="field-input" placeholder="Enter full name" autocomplete="off" />
                        <div class="field-line"></div>
                    </div>
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <!-- Gender -->
                <div class="field-group">
                    <label asp-for="Gender" class="field-label">
                        <span class="label-dot"></span>
                        Gender
                    </label>
                    <div class="field-wrapper">
                        <span class="field-icon">⬡</span>
                        <select asp-for="Gender" class="field-input">
                            <option value="" disabled selected>Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <div class="field-line"></div>
                    </div>
                    <span asp-validation-for="Gender" class="field-error"></span>
                </div>

                <!-- Age -->
                <div class="field-group">
                    <label asp-for="Age" class="field-label">
                        <span class="label-dot"></span>
                        Age
                    </label>
                    <div class="field-wrapper">
                        <span class="field-icon">◇</span>
                        <input asp-for="Age" class="field-input" placeholder="Enter age" type="number" min="1" max="120" autocomplete="off" />
                        <div class="field-line"></div>
                    </div>
                    <span asp-validation-for="Age" class="field-error"></span>
                </div>

                <!-- City -->
                <div class="field-group">
                    <label asp-for="City" class="field-label">
                        <span class="label-dot"></span>
                        City
                    </label>
                    <div class="field-wrapper">
                        <span class="field-icon">◉</span>
                        <input asp-for="City" class="field-input" placeholder="Enter city" autocomplete="off" />
                        <div class="field-line"></div>
                    </div>
                    <span asp-validation-for="City" class="field-error"></span>
                </div>

                <!-- Submit -->
                <div class="submit-row">
                    <button type="submit" class="btn-futuristic">
                        <span>Initialize Record</span>
                    </button>
                </div>
            </form>

            <div class="back-link-row">
                <a asp-action="Index" class="back-link">Return to Registry</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
